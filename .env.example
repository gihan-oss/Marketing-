# Airtable personal access token. Scopes:
#   data.records:read   — required (all dashboards)
#   data.records:write  — required for inline editing (write-back)
# Grant the token access to these bases:
#   Amal & Company Marketing   appcDlJ12Cje9tUSG
#   MAS GLA                     appHhvQGW7QaDroW8
#   Kasper Inc                  appVYXrGV4Kz33OIU
# Create one at https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# Optional: override the base the platform reads from.
AIRTABLE_BASE_ID=appcDlJ12Cje9tUSG

# Anthropic API key for the executive AI assistant (optional — the rest of
# the platform works without it).
ANTHROPIC_API_KEY=

# Brevo API key — enables the outreach send/schedule button (uses your Brevo
# templates + verified sender). Optional; without it the composer shows a
# setup notice and nothing can be sent. Create at https://app.brevo.com → SMTP & API.
BREVO_API_KEY=

# Public base URL that hosts the email template images (public/email/*). Email
# clients CANNOT load images from a Vercel *preview* deployment (behind
# Deployment Protection), so this must be your production domain with images
# publicly reachable. Used by `npm run build:email` to retarget the template.
EMAIL_ASSET_BASE_URL=https://marketing-gigi12313-s-projects13.vercel.app

# ---------------------------------------------------------------------------
# Social automation (LinkedIn / Instagram / Facebook)
# ---------------------------------------------------------------------------
# Shared secret protecting the automation endpoints (/api/social/sync,
# /api/social/publish). Vercel Cron sends it automatically as a Bearer token.
# Leave unset for local dev (endpoints are then open); ALWAYS set in production.
CRON_SECRET=

# Each channel activates only when its credentials are present; a missing
# channel is skipped. Reads (metrics sync) are always safe.
# LinkedIn — profile or administered Company Page.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=            # e.g. urn:li:organization:12345 or urn:li:person:abc
# LINKEDIN_API_VERSION=202401  # optional override

# Instagram Business account (via the Facebook Graph API).
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Facebook Page you administer.
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
# FB_GRAPH_VERSION=v21.0       # shared by Facebook + Instagram; optional override

# Phase 2 publishing (off by default to prevent accidental live posts). Set to
# "true" and pick a channel to auto-publish due, approved Content rows.
SOCIAL_PUBLISH_ENABLED=false
SOCIAL_DEFAULT_PUBLISH_CHANNEL=  # LinkedIn | Instagram | Facebook
